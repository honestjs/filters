{
	"name": "@honestjs/prisma-exception-filter",
	"version": "1.2.3",
	"description": "Prisma exception filter for HonestJS framework",
	"main": "./dist/index.js",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.mjs",
			"require": "./dist/index.js"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"clean": "rm -rf dist",
		"type-check": "tsc --noEmit",
		"lint": "prettier --check .",
		"test": "vitest run --passWithNoTests",
		"prepack": "pnpm run build"
	},
	"keywords": [
		"honestjs",
		"hono",
		"nestjs",
		"filter"
	],
	"author": "Orkhan Karimov <karimovok1@gmail.com> (https://github.com/kerimovok)",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/honestjs/filters.git",
		"directory": "packages/prisma-exception-filter"
	},
	"devDependencies": {
		"@prisma/client": "^6.19.3",
		"honestjs": "^0.1.22",
		"hono": "^4.12.12",
		"vitest": "^4.1.3"
	},
	"peerDependencies": {
		"@prisma/client": "^6.11.1",
		"honestjs": "^0.1.11",
		"hono": "^4.12.8"
	}
}
